.venv/
.venv-osim/
# out/ is artefacts (regenerable) -- EXCEPT the hand-written viewer pages, which are SOURCE.
# typing.html / anim.html / progress.html / index.html are not generated by anything; they were
# written by hand and they fetch the .json artefacts beside them. Ignoring them meant a fresh clone
# could not render a single thing.
out/*
!out/index.html
!out/typing.html
!out/anim.html
!out/progress.html
# impact.html is generated but SELF-CONTAINED (data embedded), committed so the §8.15k
# result renders straight from a clone. Regenerate with scripts/impact_view.py.
!out/impact.html
__pycache__/
.pytest_cache/
*.pyc

# PIANO hand-MRI dataset (Apache-2.0) -- 769 MB, fetched by scripts/measure_tissue.py
data/piano/
out_archive/
